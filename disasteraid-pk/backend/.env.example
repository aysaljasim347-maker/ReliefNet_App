# DisasterAid PK - Backend Environment Variables
# Copy this file to .env and fill in your values

# Server
PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/disasteraid

# JWT
JWT_SECRET=your-jwt-secret-minimum-32-chars-here

# Cloudinary (Image uploads)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Platform Bank Details (shown to donors for bank transfers)
PLATFORM_BANK_NAME=MCB Bank
PLATFORM_ACCOUNT_TITLE=DisasterAid PK
PLATFORM_ACCOUNT_NUMBER=1234567890
PLATFORM_IBAN=PK36SCBL0000001123456702

# Email (optional - for receipt delivery)
MAIL_USER=your-email@gmail.com
MAIL_PASS=your-app-password
